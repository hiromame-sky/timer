<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64">
  <!-- ドロップシャドウ -->
  <rect x="2" y="4" width="60" height="60" rx="16" fill="#000000" opacity="0.1" />
  
  <!-- タイマーの外枠（水色） -->
  <rect x="2" y="2" width="60" height="60" rx="16" fill="#9bd4e4" />
  
  <!-- 文字盤の縁取りの影 -->
  <circle cx="32" cy="32" r="26" fill="#e0e8eb" />
  
  <!-- 白い文字盤 -->
  <circle cx="32" cy="31" r="26" fill="#fdfdfd" />
  
  <!-- 残り時間（45分の状態を表す濃い青緑の扇形） -->
  <path d="M 32 31 L 32 5 A 26 26 0 1 1 6 31 Z" fill="#185d6e" />
  
  <!-- 中央のノブの影 -->
  <circle cx="32" cy="32" r="6" fill="#000000" opacity="0.15" />
  
  <!-- 中央のノブ -->
  <circle cx="32" cy="31" r="6" fill="#aee0ef" />
  
  <!-- ノブのハイライト（立体感） -->
  <circle cx="32" cy="31" r="3" fill="#ffffff" opacity="0.5" />
</svg>